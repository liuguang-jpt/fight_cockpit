{
    "version": "2.0.0",
    "tasks": [
        {
            "detail": "编译PFD主程序（pfd_main.c + pfd_ui.c），链接SDL2全套库生成pfd.exe",
            "label": "build pfd",
            "problemMatcher": [
                "$gcc"
            ],
            "command": "D:/gcc/msys64/mingw64/bin/gcc.exe",
            "type": "shell",
            "args": [
                "-g",
                "${workspaceFolder}/src/PFD/pfd_main.c",
                "${workspaceFolder}/src/PFD/pfd_ui.c",
                "-o",
                "${workspaceFolder}/build/pfd.exe",
                "-I${workspaceFolder}/src",
                "-I${workspaceFolder}/src/PFD",
                "-ID:\\gcc\\msys64\\mingw64\\include",
                "-ID:\\gcc\\msys64\\mingw64\\include\\SDL2",
                "-LD:\\gcc\\msys64\\mingw64\\lib",
                "-lmingw32",
                "-lSDL2main",
                "-lSDL2",
                "-lSDL2_gfx",
                "-lSDL2_ttf",
                "-lSDL2_image",
                "-lws2_32"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "detail": "运行PFD程序",
            "label": "run pfd",
            "dependsOn": [
                "build pfd"
            ],
            "command": "${workspaceFolder}/build/pfd.exe",
            "type": "shell",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": false
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "D:/gcc/msys64/mingw64/bin/gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-I",
                "D:/gcc/msys64/mingw64/include",
                "-I",
                "D:/gcc/msys64/mingw64/include/SDL2"
            ],
            "options": {
                "cwd": "D:/gcc/msys64/mingw64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ]
}